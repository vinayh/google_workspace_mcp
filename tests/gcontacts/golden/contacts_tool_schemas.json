        "description": "The action to perform: \"create\", \"update\", or \"delete\".",
        "enum": [
          "create",
          "update",
          "delete"
        ],
        "type": "string"
      },
      "contact_ids": {
        "anyOf": [
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of contact IDs for \"delete\" action."
      },
      "contacts": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/ContactInput"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of contact dicts for \"create\" action.\nEach dict may contain: given_name, family_name, phones, emails, organizations,\nnotes, address. Deprecated: phone, email, organization, job_title."
      },
      "field": {
        "anyOf": [
          {
            "enum": [
              "names",
              "phoneNumbers",
              "emailAddresses",
              "organizations",
              "biographies",
              "addresses"
            ],
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "For \"update\" action \u2014 the single People API field to update across\nall contacts in this batch. Required. Must be one of: names, phoneNumbers,\nemailAddresses, organizations, biographies, addresses.\nUsing a single field per batch call prevents unintentional data loss from\na union updateMask overwriting unrelated fields."
      },
      "updates": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/ContactUpdateInput"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of update dicts for \"update\" action.\nEach dict must contain contact_id and may contain the same fields as contacts."
      },
      "user_google_email": {
        "description": "The user's Google email address. Required.",
        "type": "string"
      }
